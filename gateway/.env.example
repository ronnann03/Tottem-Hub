# ============================================================
# gateway/.env.example — Variables de entorno del API Gateway
# ============================================================
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitees `.env` — está en .gitignore.
# ============================================================

# Puerto en el que escucha el servidor HTTP del Gateway.
# En producción: 3001 (detrás de un reverse proxy/load balancer).
# En desarrollo local: 3001
PORT=3001

# URL interna del backend Django (dentro de la red Docker).
# Usar nombre de servicio Docker, no localhost.
# En producción: http://backend:8000
# En desarrollo local: http://backend:8000
BACKEND_URL=http://backend:8000

# Orígenes permitidos por CORS (comma-separated, sin espacios).
# En producción: solo los dominios oficiales.
# En desarrollo local: añadir http://localhost:3000
CORS_ORIGINS=https://minkagroup.digital,https://www.minkagroup.digital

# Ventana de tiempo para el rate limiting (en milisegundos).
# 60000 = 1 minuto
RATE_LIMIT_WINDOW_MS=60000

# Número máximo de requests permitidos por IP dentro de la ventana.
RATE_LIMIT_MAX=100

# Tamaño máximo de archivo permitido en uploads (en bytes).
# 10485760 = 10 MB — primera línea de defensa (también validado en backend).
MAX_FILE_SIZE_BYTES=10485760

# URL de conexión a Redis.
# Usado para: rate limiting por IP.
# En producción: redis://redis:6379
# En desarrollo local: redis://redis:6379
REDIS_URL=redis://redis:6379

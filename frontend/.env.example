# ============================================================
# frontend/.env.example — Variables de entorno del Frontend
# ============================================================
# Copia este archivo a `.env.local` y rellena los valores reales.
# NUNCA commitees `.env.local` — está en .gitignore.
# ============================================================

# URL pública del API Gateway (accesible desde el navegador).
# En producción: https://api.minkagroup.digital
# En desarrollo local: http://localhost:3001
NEXT_PUBLIC_GATEWAY_URL=https://api.minkagroup.digital

# URL pública de la aplicación frontend.
# Usada para construir links absolutos (emails, redirects, OG tags).
# En producción: https://minkagroup.digital
# En desarrollo local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://minkagroup.digital

# ============================================================
# backend/.env.example — Variables de entorno del Backend (Django)
# ============================================================
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitees `.env` — está en .gitignore.
# ============================================================

# ── Base de Datos ────────────────────────────────────────────

# URL de conexión a PostgreSQL.
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# En desarrollo local (Docker): postgresql://postgres:postgres@db:5432/tottemhub
DATABASE_URL=postgresql://usuario:contraseña@db:5432/tottemhub

# ── Redis ────────────────────────────────────────────────────

# URL de conexión a Redis.
# Usado para: allowlist JWT (refresh tokens) + broker Celery.
# En desarrollo local (Docker): redis://redis:6379
REDIS_URL=redis://redis:6379

# ── Storage de Archivos ──────────────────────────────────────

# Backend de almacenamiento de archivos (intercambiable entre S3 y GCS).
# Producción S3:  storages.backends.s3boto3.S3Boto3Storage
# Producción GCS: storages.backends.gcloud.GoogleCloudStorage
# Desarrollo local (archivos en disco): django.core.files.storage.FileSystemStorage
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage

# Nombre del bucket S3/GCS donde se almacenan los archivos subidos.
AWS_STORAGE_BUCKET_NAME=minka-files

# Credenciales de acceso a AWS S3.
# En GCS: usar las variables equivalentes de django-storages.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ── JWT y Autenticación ──────────────────────────────────────

# Clave secreta para firmar los tokens JWT.
# Debe ser un string largo, aleatorio y único por entorno.
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-secret-key-here

# Duración del access token en minutos.
# Valor fijo de arquitectura: 15 minutos.
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# Duración del refresh token en días.
# Valor fijo de arquitectura: 7 días. Almacenado en Redis allowlist.
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Frontend ─────────────────────────────────────────────────

# URL base del frontend (Next.js). Se usa para construir el enlace de verificación de email.
FRONTEND_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────

# Backend de envío de emails Django.
# Producción: django.core.mail.backends.smtp.EmailBackend
# Desarrollo/tests: django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Host SMTP para el envío de emails transaccionales.
# Producción: smtp.sendgrid.net (SendGrid)
EMAIL_HOST=smtp.sendgrid.net

# ── Celery ───────────────────────────────────────────────────

# URL del broker Celery (Redis, base de datos 0).
# En desarrollo local (Docker): redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ── Reglas de Negocio Configurables ─────────────────────────

# Días tras la fecha de regreso del viaje para archivar automáticamente
# los documentos entregados (tarea Celery: archivar_viajes_finalizados).
DOCS_ARCHIVE_DAYS_AFTER_RETURN=30

# Porcentaje de documentos completados por debajo del cual se activa
# la alerta al agente (tarea Celery: alerta_docs_umbral).
# Ejemplo: 30 = alerta cuando menos del 30% de docs están completados.
DOC_INCOMPLETE_ALERT_THRESHOLD=30
